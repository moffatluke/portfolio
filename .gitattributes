# Normalize line endings to LF in the repo AND the working tree, regardless of
# a contributor's core.autocrlf setting. This matters here because the
# knowledge-base ingestion reads these files directly: a CRLF checkout used to
# defeat the markdown chunker's heading regex and silently drop section headers.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
